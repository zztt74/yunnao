# 复制为 .env 后替换为本机开发配置；不要提交 .env。
MYSQL_DATABASE=cloud_brain
MYSQL_USER=cloud_brain
MYSQL_PASSWORD=replace-with-local-password
MYSQL_ROOT_PASSWORD=replace-with-local-root-password
MYSQL_PORT=3306
DB_URL=jdbc:mysql://localhost:3306/cloud_brain?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
DB_USERNAME=cloud_brain
DB_PASSWORD=replace-with-local-password

BACKEND_PORT=8080
FRONTEND_PORT=8088
PRISM_PORT=4010

JWT_SECRET=replace-with-at-least-32-byte-local-secret
INITIAL_ADMIN_USERNAME=replace-with-local-admin
INITIAL_ADMIN_PASSWORD=replace-with-local-admin-password
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8088

AI_MODE=MOCK
AI_API_URL=
AI_API_KEY=
